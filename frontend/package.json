{
  "name": "kodo",
  "private": true,
  "version": "0.1.0",
  "description": "App personal de escritorio con Dashboard, Notas, Recordatorios, Calendario, Rutina, To-Do y Tracking",
  "author": "Manzft",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --linux --win",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:win": "vite build && electron-builder --win"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.manzft.kodo",
    "productName": "Kodo",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/kodo-backend",
        "to": "backend/kodo-backend"
      }
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    }
  }
}
